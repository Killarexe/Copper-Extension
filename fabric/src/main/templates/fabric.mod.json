{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "${mod_authors}"
  ],
  "contributors": [
    "${mod_credits}"
  ],
  "contact": {
    "homepage": "${mod_homepage}",
    "sources": "${mod_sources}",
    "issues": "${mod_issues_page}"
  },
  "license": "${mod_license}",
  "icon": "assets/copper_extension/logo.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "github.killarexe.copper_extension.fabric.CEFabric"
    ],
    "fabric-datagen": [
      "github.killarexe.copper_extension.fabric.generation.data.CEDataGenerator"
    ]
  },
  "mixins": [
    "copper_extension_fabric.mixins.json"
  ],
  "depends": {
    "minecraft": "${fabric_minecraft_version_range}",
    "fabricloader": "${fabric_loader_version_range}",
    "fabric-api": "${fabric_api_version_range}"
  }
}